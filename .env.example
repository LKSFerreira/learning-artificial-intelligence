# =============================================================================
# Aprendendo IA — variáveis de ambiente (exemplo)
# =============================================================================
# Copie para `.env` e preencha. NÃO commite o `.env`.
#
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (Linux/macOS)
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Google Gemini — chave de API (segredo)
# -----------------------------------------------------------------------------
# Tutor no app + scripts de síntese de voz (CLI).
# Sem ela o site roda; o tutor só avisa que falta configurar.
# https://ai.google.dev/
#
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# 2) Áudio — UM prefixo de host (não é uma URL por lição)
# -----------------------------------------------------------------------------
#
# NÃO é assim (errado / não usamos):
#   URL_INTRO=https://...
#   URL_HIERARCHY=https://...
#   URL_IA=https://...
# (uma variável não “sobrescreve” a outra lição)
#
# É assim (certo):
#   UMA base = o servidor/CDN onde ficam TODOS os MP3
#   + regra fixa de pastas no código:
#
#     {BASE}/{voz}/{licaoId}.mp3
#
#   voz     = Aoede  ou  Kore
#   licaoId = id da lição (intro, hierarchy, ia, ml, dl, ...)
#
# Exemplos com a MESMA base:
#   https://cdn.exemplo.com/Aoede/intro.mp3
#   https://cdn.exemplo.com/Kore/intro.mp3
#   https://cdn.exemplo.com/Aoede/hierarchy.mp3
#   https://cdn.exemplo.com/Aoede/ia.mp3
#   https://cdn.exemplo.com/Kore/ml.mp3
#
# Só muda o final do caminho (voz + id). A base é sempre a mesma.
#
# --- Desenvolvimento local ---
# Deixe VAZIO. O app usa arquivos em public/audios/:
#   /audios/Aoede/intro.mp3  →  public/audios/Aoede/intro.mp3
#
# --- Produção (R2, Supabase Storage, etc.) ---
# Cole a URL pública do bucket, SEM barra no final.
#   VITE_AUDIO_BASE_URL=https://pub-xxxx.r2.dev
#   VITE_AUDIO_BASE_URL=https://SEUPROJETO.supabase.co/storage/v1/object/public/audios
#
# Prefixo VITE_ = variável visível no front (import.meta.env.VITE_AUDIO_BASE_URL).
# Isso é URL pública de arquivos, não senha.
#
VITE_AUDIO_BASE_URL=


# -----------------------------------------------------------------------------
# Resumo rápido
# -----------------------------------------------------------------------------
# GEMINI_API_KEY        → segredo da API (tutor + gerar áudio)
# VITE_AUDIO_BASE_URL   → um host para todos os MP3 (opcional no dev)
#
# Layout: docs/padrao_layout_licao.md
# Travessões: npm run lint:travessoes
